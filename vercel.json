{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "cleanUrls": true,
  "trailingSlash": true,
  "redirects": [
    {
      "source": "/admin",
      "destination": "/admin/",
      "permanent": true
    },
    {
      "source": "/user",
      "destination": "/user/",
      "permanent": true
    },
    {
      "source": "/dev",
      "destination": "/dev/",
      "permanent": true
    },
    {
      "source": "/login",
      "destination": "/login/",
      "permanent": true
    }
  ]
}
